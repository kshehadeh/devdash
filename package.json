{
  "name": "devdash",
  "version": "0.1.1",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"bun run dev\" \"wait-on http://localhost:3000 && bun run electron:compile && electron electron/dist/main.js\"",
    "electron:build": "bun run build && bun run electron:compile && electron-builder",
    "electron:build:publish": "bun run build && bun run electron:compile && electron-builder --publish always",
    "electron:start": "cross-env NODE_ENV=production bun run electron:compile && electron electron/dist/main.js",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "release": "bash scripts/version.sh"
  },
  "build": {
    "appId": "com.devdash.app",
    "productName": "DevDash",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "electron/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/static",
        "to": ".next/static"
      },
      {
        "from": "public",
        "to": "public"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**"
    ],
    "afterPack": "scripts/after-pack.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "kshehadeh",
      "repo": "devdash"
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "electron-winstaller",
    "sharp",
    "unrs-resolver"
  ]
}
