{
  "name": "devdash",
  "version": "0.3.3",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && bun run electron:compile && electron electron/dist/main.js\"",
    "build": "vite build",
    "lint": "eslint",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:build": "bun run build && bun run electron:compile && electron-builder",
    "electron:build:local": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false bun run build && bun run electron:compile && electron-builder --config.mac.notarize=false",
    "electron:build:publish": "bun run build && bun run electron:compile && electron-builder --publish always",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "migrate-smoke": "bun run electron:compile && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/migrate-smoke.cjs",
    "release": "bash scripts/version.sh",
    "publish-release": "bun scripts/publish-release.ts"
  },
  "build": {
    "appId": "com.devdash.app",
    "productName": "DevDash",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": true
    },
    "publish": {
      "provider": "github",
      "owner": "kshehadeh",
      "repo": "devdash"
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "inquirer": "^13.3.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "electron-winstaller",
    "sharp",
    "unrs-resolver"
  ]
}
