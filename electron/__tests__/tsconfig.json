{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "ES2022.Error"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["vitest/globals"]
  },
  "include": ["./**/*.ts", "../db/**/*.ts", "../sync/**/*.ts", "../services/**/*.ts", "../types.ts", "../jira-status-category.ts"],
  "exclude": []
}
